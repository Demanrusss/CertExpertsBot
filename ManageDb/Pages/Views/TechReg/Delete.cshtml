@page "/TechReg/Delete"
@model ManageDb.Pages.Views.TechReg.DeleteModel

<h1>@ViewData["Title"]</h1>

<h3>Вы уверены, что хотите удалить запись?</h3>
<div>
    <h4>Технический регламент</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TechRegModel.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TechRegModel.Name)
        </dd>
    </dl>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TechRegModel.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TechRegModel.Description)
        </dd>
    </dl>
    <br />
    <form method="post">
        <input type="hidden" asp-for="TechRegModel.Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-page="./Index">Назад к списку</a>
    </form>
</div>
