@page "/TechReg/Create"
@model ManageDb.Pages.Views.TechReg.CreateModel

<h1>@ViewData["Title"]</h1>

<h4>Технический регламент</h4>
<hr />
<div class="row">
    <div class="col-md-12">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="form-group col-md-6">
                    <label asp-for="TechRegModel.Name" class="control-label"></label>
                    <textarea asp-for="TechRegModel.Name" class="form-control" required onchange="trim(this)"></textarea>
                    <span asp-validation-for="TechRegModel.Name" class="text-danger"></span>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="TechRegModel.Description" class="control-label"></label>
                    <textarea asp-for="TechRegModel.Description" class="form-control" required onchange="trim(this)"></textarea>
                    <span asp-validation-for="TechRegModel.Description" class="text-danger"></span>
                </div>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Создать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Назад к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/site.js"></script>
}
