@page "/TNVEDCode/Edit"
@model ManageDb.Pages.Views.TNVEDCode.EditModel

<h1>@ViewData["Title"]</h1>

<h4>Код ТН ВЭД</h4>
<hr />
<div class="row">
    <div class="col-md-5">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="TnvedCodeModel.Id" />
            <div class="form-group">
                <label asp-for="TnvedCodeModel.Code" class="control-label"></label>
                <input asp-for="TnvedCodeModel.Code" class="form-control" onchange="trim(this)" />
                <span asp-validation-for="TnvedCodeModel.Code" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TnvedCodeModel.Name" class="control-label"></label>
                <input asp-for="TnvedCodeModel.Name" class="form-control" onchange="trim(this)" />
                <span asp-validation-for="TnvedCodeModel.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TnvedCodeModel.TechRegs" class="control-label"></label>
                <select name="TNVEDCode_TechRegs" class="form-control" size="@(Model.TechRegNameMSL.Count() + Model.TnvedCodeModel.TechRegs.Count)" asp-for="TnvedCodeModel.TechRegs" asp-items="Model.TechRegNameMSL" multiple>
                @foreach (var techReg in Model.TnvedCodeModel.TechRegs)
                {
                    <option value="@techReg.Id" selected>@techReg.Name</option>
                }
                </select>
                
                <span asp-validation-for="TnvedCodeModel.TechRegs" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Назад к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
